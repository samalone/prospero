# 1Password secret injection template for Prospero dev secrets.
#
# Generate with `scripts/inject-secrets.sh` which runs `op inject` to
# replace the op:// references with base64-encoded values from 1Password
# and writes k8s/overlays/dev/secrets.yaml (gitignored).
#
# Required 1Password item:
#   Vault: llama-infrastructure
#   Item: prospero-dev
#   Fields:
#     - database-url-base64 (text field): base64 of
#         postgresql://prospero:PASSWORD@postgres.life-balance.svc.cluster.local:5432/prospero
#
# The dev database lives in the local docker-desktop cluster's
# `life-balance` namespace — same Postgres pod Life Balance uses.

apiVersion: v1
kind: Secret
metadata:
  name: prospero-secrets
type: Opaque
data:
  DATABASE_URL: op://llama-infrastructure/prospero-dev/database-url-base64
